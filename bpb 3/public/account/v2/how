async function loadProposalRequests(clientId) {
  const el = document.getElementById('v2-prop-requests');
  if (!el) return;
  const [{ data: redesigns }, { data: subs }] = await Promise.all([
    supabase.from('proposal_redesign_requests')
      .select('id, proposal_id, status, homeowner_note, designer_response, created_at, reviewed_at, photo_url')
      .eq('client_id', clientId)
      .order('created_at', { ascending: false }),
    supabase.from('proposal_substitutions')
      .select('id, proposal_id, status, homeowner_note, designer_response, created_at, reviewed_at')
      .eq('client_id', clientId)
      .order('created_at', { ascending: false }),
  ]);
  const items = [
    ...(redesigns || []).map(r => ({ ...r, kind: 'redesign' })),
    ...(subs || []).map(s => ({ ...s, kind: 'substitution' })),
  ].sort((a, b) => new Date(b.created_at) - new Date(a.created_at));

  if (!items.length) {
    el.innerHTML = `
      <div class="v2-pane-eyebrow" style="margin-bottom:14px;">Your requests</div>
      <div class="v2-empty">
        <div class="v2-empty-icon">📝</div>
        <h3>No requests yet</h3>
        <p>Use <strong>Request redesign</strong> or <strong>Change materials</strong> on a proposal above to submit a change.</p>
      </div>`;
    return;
  }

  el.innerHTML = `
    <div class="v2-pane-eyebrow" style="margin-bottom:14px;">Your requests</div>
    <div style="background:#fff;border:1px solid var(--bp-border);border-radius:12px;overflow:hidden;">
      ${items.map(it => {
        const status = it.status || 'pending';
        const badge = ({
          pending:   { bg: 'var(--bp-cream)', fg: 'var(--bp-muted)', label: 'Pending' },
          reviewing: { bg: '#fef3c7',         fg: '#92400e',         label: 'In review' },
          approved:  { bg: '#dcfce7',         fg: '#166534',         label: 'Approved' },
          completed: { bg: 'var(--bp-green)', fg: '#fff',            label: 'Completed' },
          declined:  { bg: '#fee2e2',         fg: '#991b1b',         label: 'Declined' },
        })[status] || { bg: 'var(--bp-cream)', fg: 'var(--bp-muted)', label: status };
        const icon = it.kind === 'redesign' ? '✏️' : '🔄';
        const kindLabel = it.kind === 'redesign' ? 'Redesign request' : 'Material swap';
        return `
          <div style="padding:14px 18px;border-top:1px solid var(--bp-border);">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;">
              <div style="min-width:0;flex:1;">
                <div style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--bp-muted);font-weight:700;">${icon} ${kindLabel}</div>
                <div style="font-size:13px;color:var(--bp-charcoal);margin-top:4px;line-height:1.5;">${escapeHtml(it.homeowner_note || '(no note)')}</div>
                ${it.designer_response ? `<div style="margin-top:8px;padding:10px 12px;background:var(--bp-green-soft);border-radius:8px;font-size:12px;color:var(--bp-text);"><strong style="color:var(--bp-green-dk);">Designer reply:</strong> ${escapeHtml(it.designer_response)}</div>` : ''}
                <div style="font-size:11px;color:var(--bp-muted);margin-top:6px;">Submitted ${formatDate(it.created_at)}${it.reviewed_at ? ' · reviewed ' + formatDate(it.reviewed_at) : ''}</div>
              </div>
              <span style="display:inline-block;padding:3px 10px;border-radius:999px;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:${badge.bg};color:${badge.fg};white-space:nowrap;flex-shrink:0;">${badge.label}</span>
            </div>
          </div>`;
      }).join('')}
    </div>
  `;
}

async function loadReferrals(clientId) {
  const listEl = document.getElementById('v2-refer-list');
  const { data, error } = await supabase
    .from('referrals')
    .select('id, referred_name, referred_email, status, invite_sent_at, scheduled_at, appointment_completed_at, credit_awarded_at, credit_amount_cents, created_at')
    .eq('referrer_client_id', clientId)
    .order('created_at', { ascending: false });
  if (error) { listEl.innerHTML = `<div class="v2-error-msg">${escapeHtml(error.message)}</div>`; return; }
  if (!data || data.length === 0) {
    listEl.innerHTML = `
      <div class="v2-empty">
        <div class="v2-empty-icon">🎁</div>
        <h3>No referrals yet</h3>
        <p>Send your first invitation above. Every successful referral earns you $500 toward your next project.</p>
      </div>`;
    return;
  }
  listEl.innerHTML = `
    <div style="background:#fff;border:1px solid var(--bp-border);border-radius:12px;overflow:hidden;">
      ${data.map(r => {
        const status = r.status || 'invited';
        const cents = r.credit_amount_cents || 0;
        const earned = !!r.credit_awarded_at;
        const badge = ({
          invited:   { bg: 'var(--bp-cream)', fg: 'var(--bp-muted)',   label: 'Invited' },
          scheduled: { bg: '#fef3c7',         fg: '#92400e',           label: 'Scheduled' },
          completed: { bg: '#dcfce7',         fg: '#166534',           label: 'Completed' },
          credited:  { bg: 'var(--bp-green)', fg: '#fff',              label: 'Credited' },
          expired:   { bg: '#f3f4f6',         fg: 'var(--bp-muted)',   label: 'Expired' },
        })[status] || { bg: 'var(--bp-cream)', fg: 'var(--bp-muted)', label: status };
        return `
          <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;padding:14px 18px;border-top:1px solid var(--bp-border);">
            <div style="min-width:0;flex:1;">
              <div style="font-size:13px;font-weight:600;color:var(--bp-text);">${escapeHtml(r.referred_name || r.referred_email || '—')}</div>
              <div style="font-size:11px;color:var(--bp-muted);margin-top:2px;">${escapeHtml(r.referred_email || '')} · invited ${formatDate(r.invite_sent_at || r.created_at)}</div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
              ${earned ? `<span style="font-size:13px;font-weight:600;color:var(--bp-green-dk);">+${formatUSD(cents)}</span>` : ''}
              <span style="display:inline-block;padding:3px 10px;border-radius:999px;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:${badge.bg};color:${badge.fg};">${badge.label}</span>
            </div>
          </div>`;
      }).join('')}
    </div>
    <div style="font-size:11px;color:var(--bp-muted);margin-top:10px;text-align:right;">${data.length} ${data.length === 1 ? 'referral' : 'referrals'} total</div>
  `;
}

function wireReferModal() {
  const modal = document.getElementById('v2-refer-modal');
  const openBtn = document.getElementById('v2-refer-invite');
  const closeBtn = document.getElementById('v2-refer-close');
  const cancelBtn = document.getElementById('v2-refer-cancel');
  const submitBtn = document.getElementById('v2-refer-submit');
  const copyBtn = document.getElementById('v2-refer-copy');
  const errEl = document.getElementById('v2-refer-error');

  const open = () => { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; errEl.style.display = 'none'; };
  const close = () => { modal.style.display = 'none'; document.body.style.overflow = ''; };
  openBtn.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  cancelBtn.addEventListener('click', close);
  modal.addEventListener('click', e => { if (e.target === modal) close(); });

  copyBtn.addEventListener('click', async () => {
    const url = `${window.location.origin}/refer/?code=${encodeURIComponent(currentClient.refer_code || '')}`;
    try {
      await navigator.clipboard.writeText(url);
      copyBtn.textContent = '✓ Copied!';
      setTimeout(() => { copyBtn.textContent = '🔗 Copy share link'; }, 2000);
    } catch (_) {
      window.prompt('Copy this link:', url);
    }
  });

  submitBtn.addEventListener('click', async () => {
    const name = document.getElementById('v2-refer-name').value.trim();
    const email = document.getElementById('v2-refer-email').value.trim();
    const phone = document.getElementById('v2-refer-phone').value.trim();
    const note = document.getElementById('v2-refer-note').value.trim();
    if (!name || !email) { errEl.textContent = 'Name and email are required.'; errEl.style.display = 'block'; return; }
    submitBtn.disabled = true; submitBtn.textContent = 'Sending...';
    try {
      const res = await fetch('/api/refer/send-invite', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone, note, refer_code: currentClient.refer_code }),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        throw new Error(j.error || `Send failed (${res.status})`);
      }
      close();
      ['v2-refer-name','v2-refer-email','v2-refer-phone','v2-refer-note'].forEach(id => document.getElementById(id).value = '');
      await loadReferrals(currentClient.id);
    } catch (e) {
      errEl.textContent = e.message || 'Could not send invitation. Please try again.';
      errEl.style.display = 'block';
    } finally {
      submitBtn.disabled = false; submitBtn.textContent = 'Send invitation';
    }
  });
}

// Helpers
function formatUSD(cents) {
  const d = (Number(cents) || 0) / 100;
  return d.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: d % 1 === 0 ? 0 : 2 });
}
function formatDate(iso) {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
function formatStatus(s) {
  const map = { draft: 'Draft', sent: 'Sent', viewed: 'Viewed', signed: 'Signed', in_progress: 'In progress', complete: 'Complete' };
  return map[s] || s;
}
function escapeHtml(s) {
  return String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}
function escapeAttr(s) { return escapeHtml(s); }
