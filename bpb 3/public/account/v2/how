// Sidebar nav
function activatePane(slug) {
  document.querySelectorAll('.v2-nav-btn').forEach(b =>
    b.classList.toggle('is-active', b.dataset.pane === slug)
  );
  document.querySelectorAll('.v2-pane').forEach(p =>
    p.classList.toggle('is-active', p.dataset.pane === slug)
  );
  if (window.location.hash !== '#' + slug) {
    history.replaceState(null, '', '#' + slug);
  }
  window.scrollTo({ top: 0, behavior: 'instant' });
}
navEl.addEventListener('click', e => {
  const btn = e.target.closest('.v2-nav-btn');
  if (!btn) return;
  activatePane(btn.dataset.pane);
});
document.querySelectorAll('[data-jump-pane]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    activatePane(a.dataset.jumpPane);
  });
});
window.addEventListener('hashchange', () => {
  const slug = (window.location.hash || '#overview').slice(1);
  if (document.querySelector(`[data-pane="${slug}"]`)) activatePane(slug);
});

document.getElementById('v2-signout').addEventListener('click', async () => {
  try { await supabase.auth.signOut(); } catch (_) {}
  window.location.replace('/account/signin.html');
});

// Auth gate
const { data: { session } } = await supabase.auth.getSession();
if (!session) {
  window.location.replace('/account/signin.html?next=/account/v2/');
} else {
  await loadAccount();
}

const initialHash = (window.location.hash || '#overview').slice(1);
if (document.querySelector(`[data-pane="${initialHash}"]`)) activatePane(initialHash);

function showError(msg) {
  errorBanner.textContent = msg;
  errorBanner.style.display = 'block';
}

async function loadAccount() {
  const { data: { user } } = await supabase.auth.getUser();
  const { data: client, error: clientErr } = await supabase
    .from('clients')
    .select('id, name, email, phone, refer_code, must_change_password, referral_credit_cents, referral_credit_used_cents')
    .eq('user_id', user.id)
    .maybeSingle();
  if (clientErr) { showError('Could not load your account: ' + clientErr.message); return; }
  if (!client) { showError('Homeowner account not found. Visit /login.html for team accounts.'); return; }
  if (client.must_change_password) {
    window.location.replace('/account/set-password.html');
    return;
  }
  currentClient = client;
  const firstName = (client.name || '').split(/[\s,&]+/)[0] || 'there';
  userName.textContent = client.name || client.email || '—';
  userEmail.textContent = client.email || '';
  overviewGreet.textContent = `Welcome, ${firstName}`;

  // Prefill Acuity with client info
  const nameParts = (client.name || '').trim().split(/\s+/);
  const acuityParams = new URLSearchParams();
  if (nameParts[0]) acuityParams.set('firstName', nameParts[0]);
  if (nameParts.length > 1) acuityParams.set('lastName', nameParts.slice(1).join(' '));
  if (client.email) acuityParams.set('email', client.email);
  if (client.phone) acuityParams.set('phone', client.phone);
  scheduleCta.href = 'https://baysidepaversfreeconsultation.as.me/?' + acuityParams.toString();

  applyCreditState(client);
  await Promise.all([
    loadProposals(client.id),
    loadReferrals(client.id),
  ]);
  wireReferModal();
}

function applyCreditState(c) {
  const earned = Number(c.referral_credit_cents || 0);
  const used = Number(c.referral_credit_used_cents || 0);
  const avail = Math.max(0, earned - used);
  creditAmount.textContent = formatUSD(avail);
  creditCap.textContent = `of ${formatUSD(REFERRAL_CAP_CENTS)} max`;
  const pct = Math.min(100, Math.round((earned / REFERRAL_CAP_CENTS) * 100));
  requestAnimationFrame(() => { creditFill.style.width = pct + '%'; });
}

async function loadProposals(clientId) {
  const { data: links, error: linksErr } = await supabase
    .from('client_proposals')
    .select('proposal_id, status, sent_at, first_viewed_at, signed_at')
    .eq('client_id', clientId)
    .order('sent_at', { ascending: false });
  if (linksErr) {
    propArea.innerHTML = `<div class="v2-error-msg">Could not load proposals: ${escapeHtml(linksErr.message)}</div>`;
    printArea.innerHTML = propArea.innerHTML;
    return;
  }
  if (!links || links.length === 0) {
    const emptyHtml = `
      <div class="v2-empty">
        <div class="v2-empty-icon">📐</div>
        <h3>No proposals yet</h3>
        <p>Your designer will publish your proposal here when it's ready.</p>
        <a class="v2-btn v2-btn-primary" href="${escapeAttr(scheduleCta.href)}" target="_blank" rel="noopener" style="padding:11px 22px;">📅 Schedule a free design appointment</a>
      </div>`;
    propArea.innerHTML = emptyHtml;
    printArea.innerHTML = emptyHtml;
    propBadge.textContent = '0';
    setOverviewEmpty();
    return;
  }

  const proposalIds = links.map(l => l.proposal_id);
  const [{ data: proposals }, { data: pubs }] = await Promise.all([
    supabase.from('proposals').select('id, project_address, project_city, project_state, bid_total_amount, generated_html_slug, project_type, updated_at').in('id', proposalIds),
    supabase.from('published_proposals').select('proposal_id, slug, project_address, total_amount, published_at').in('proposal_id', proposalIds),
  ]);
  const propMap = new Map((proposals || []).map(p => [p.id, p]));
  const pubMap = new Map();
  (pubs || []).forEach(pub => {
    const e = pubMap.get(pub.proposal_id);
    if (!e || new Date(pub.published_at) > new Date(e.published_at)) pubMap.set(pub.proposal_id, pub);
  });
  propBadge.textContent = String(links.length);

  // Render
  propArea.innerHTML = links.map(link => renderProposalCard(link, propMap, pubMap, false)).join('');
  printArea.innerHTML = links.map(link => renderProposalCard(link, propMap, pubMap, true)).join('');

  // Wire redesign + substitution buttons
  propArea.addEventListener('click', e => {
    const rBtn = e.target.closest('[data-redesign]');
    if (rBtn && window.openRedesignModal) {
      window.openRedesignModal(rBtn.dataset.redesign, currentClient.id, rBtn.dataset.addr);
      return;
    }
    const sBtn = e.target.closest('[data-substitute]');
    if (sBtn && window.openSubstitutionModal) {
      window.openSubstitutionModal(sBtn.dataset.substitute, currentClient.id, sBtn.dataset.addr);
    }
  });

  // Append request history
  const histEl = document.createElement('div');
  histEl.id = 'v2-prop-requests';
  histEl.style.marginTop = '32px';
  propArea.appendChild(histEl);
  await loadProposalRequests(currentClient.id);

  // Refresh history on save
  window.addEventListener('v2-redesign-saved', () => loadProposalRequests(currentClient.id));
  window.addEventListener('v2-substitution-saved', () => loadProposalRequests(currentClient.id));

  // Latest proposal → overview hero + stats
  const latest = links[0];
  LATEST_PROPOSAL = { link: latest, prop: propMap.get(latest.proposal_id), pub: pubMap.get(latest.proposal_id) };
  renderOverviewFromLatest();
}

function renderProposalCard(link, propMap, pubMap, printOnly) {
  const prop = propMap.get(link.proposal_id);
  const pub = pubMap.get(link.proposal_id);
  const address = (pub && pub.project_address) || (prop && prop.project_address) || 'Your project';
  const cityState = prop && prop.project_city
    ? `${prop.project_city}${prop.project_state ? ', ' + prop.project_state : ''}` : '';
  const totalCents = pub && pub.total_amount != null
    ? Math.round(Number(pub.total_amount) * 100)
    : (prop && prop.bid_total_amount != null ? Math.round(Number(prop.bid_total_amount) * 100) : null);
  const totalDisplay = totalCents != null ? formatUSD(totalCents) : '—';
  const slug = (pub && pub.slug) || (prop && prop.generated_html_slug) || null;
  const viewUrl = slug ? `/p/${slug}` : null;
  const status = link.status || 'sent';
  const printUrl = `/account/print.html?id=${encodeURIComponent(link.proposal_id)}`;

  const actions = printOnly
    ? `<a class="v2-btn v2-btn-primary" href="${printUrl}" target="_blank" rel="noopener">🖨️ Print plan to mark up</a>`
    : (viewUrl
        ? `<a class="v2-btn v2-btn-primary" href="${viewUrl}" target="_blank" rel="noopener">View proposal →</a>
           <button class="v2-btn v2-btn-ghost" type="button" data-redesign="${escapeAttr(link.proposal_id)}" data-addr="${escapeAttr(address)}">✏️ Request redesign</button>
           <button class="v2-btn v2-btn-ghost" type="button" data-substitute="${escapeAttr(link.proposal_id)}" data-addr="${escapeAttr(address)}">🔄 Change materials</button>
           <a class="v2-btn v2-btn-ghost" href="${printUrl}" target="_blank" rel="noopener">🖨️ Print to mark up</a>`
        : `<button class="v2-btn v2-btn-primary" disabled>Not published yet</button>`);

  return `
    <div class="v2-prop-card">
      <div class="v2-prop-head">
        <div class="v2-prop-head-info">
          <span class="v2-prop-status ${status}">${formatStatus(status)}</span>
          <div class="v2-prop-addr">${escapeHtml(address)}</div>
          ${cityState ? `<div class="v2-prop-meta">${escapeHtml(cityState)}</div>` : ''}
        </div>
        <div class="v2-prop-total">${totalDisplay}</div>
      </div>
      <div class="v2-prop-actions">${actions}</div>
    </div>`;
}

function setOverviewEmpty() {
